{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "./dist/mcp",
		"rootDir": ".",
		"paths": {
			"$lib/*": ["./src/lib/*"]
		}
	},
	"include": ["mcp-server.ts", "src/mcp/**/*", "src/lib/server/**/*", "src/lib/types/**/*", "src/lib/utils/**/*"]
}
